# Copy this file to .env and fill in real values.
# vault-init seeds API tokens into Vault at startup under secret/<microservice>.
# mariadb credentials are used directly by the mariadb container and by event-hub.

# ── External API tokens (seeded into Vault) ──────────────────────────────────
LIVE_MS_JAVA_OLHOVIVO_TOKEN=
NVIDIA_NIM_API_KEY=
