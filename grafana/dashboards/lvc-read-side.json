        {
          "datasource": { "type": "mysql", "uid": "mariadb-virtual-areas" },
          "dataset": "virtual_areas",
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT a.id, a.name, a.action, AVG(jt.lat) AS lat, AVG(jt.lon) AS lon, SQRT(POW((MAX(jt.lat) - MIN(jt.lat)) * 111000, 2) + POW((MAX(jt.lon) - MIN(jt.lon)) * 111000 * COS(RADIANS(AVG(jt.lat))), 2)) / 2 AS size_px FROM areas a JOIN JSON_TABLE(a.coordinates, '$[*]' COLUMNS (lat DOUBLE PATH '$.lat', lon DOUBLE PATH '$.lon')) jt WHERE a.area_type IN ('POLYGON','CORRIDOR') AND a.active = 1 AND (a.id IN (${area:sqlstring})) GROUP BY a.id, a.name, a.action",
