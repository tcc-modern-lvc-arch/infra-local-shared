          "refId": "CIRC",
          "sql": { "columns": [], "groupBy": [], "limit": 50 }
        },
        {
          "datasource": { "type": "mysql", "uid": "mariadb-virtual-areas" },
          "dataset": "virtual_areas",
          "editorMode": "code",
          "format": "table",
          "rawSql": "SELECT a.name AS label, AVG(jt.lat) AS lat, AVG(jt.lon) AS lon FROM areas a JOIN JSON_TABLE(a.coordinates, '$[*]' COLUMNS (lat DOUBLE PATH '$.lat', lon DOUBLE PATH '$.lon')) jt WHERE a.area_type IN ('POLYGON','CORRIDOR') AND a.active = 1 AND (a.id IN (${area:sqlstring})) GROUP BY a.id, a.name UNION ALL SELECT a.name AS label, CAST(JSON_VALUE(a.coordinates, '$[0].lat') AS DOUBLE) AS lat, CAST(JSON_VALUE(a.coordinates, '$[0].lon') AS DOUBLE) AS lon FROM areas a WHERE a.area_type = 'CIRCLE' AND a.active = 1 AND (a.id IN (${area:sqlstring}))",
          "refId": "LABEL",
          "sql": { "columns": [], "groupBy": [], "limit": 50 }
        },
